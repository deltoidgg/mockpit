{
  "name": "@mockpit/browser",
  "version": "0.0.1",
  "description": "Browser client and audited fetch facade for MockPit.",
  "license": "MIT",
  "author": "rerixo",
  "repository": {
    "type": "git",
    "url": "https://github.com/deltoidgg/mockpit.git",
    "directory": "packages/browser"
  },
  "homepage": "https://github.com/deltoidgg/mockpit/tree/main/packages/browser#readme",
  "bugs": "https://github.com/deltoidgg/mockpit/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/browser/src"
  },
  "dependencies": {
    "@mockpit/core": "workspace:*"
  },
  "devDependencies": {
    "effect": "^3.19.6"
  }
}
