{
  "name": "@mockpit/cli",
  "version": "0.0.0",
  "description": "MockPit command-line tools for setup checks and route audits.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mockpit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/cli/src"
  },
  "dependencies": {
    "@mockpit/core": "workspace:*"
  },
  "peerDependencies": {
    "playwright": ">=1.50"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "playwright": "^1.57.0"
  }
}
