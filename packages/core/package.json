{
  "name": "@mockpit/core",
  "version": "0.0.0",
  "description": "Framework-neutral provenance model and policies for MockPit.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/core/src"
  },
  "dependencies": {
    "effect": "^3.19.6"
  }
}
