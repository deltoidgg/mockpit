{
  "name": "@mockpit/core",
  "version": "0.0.1",
  "description": "Framework-neutral provenance model and policies for MockPit.",
  "license": "MIT",
  "author": "rerixo",
  "repository": {
    "type": "git",
    "url": "https://github.com/deltoidgg/mockpit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/deltoidgg/mockpit/tree/main/packages/core#readme",
