{
  "name": "@mockpit/devtools",
  "version": "0.0.0",
  "description": "Framework-neutral Shadow DOM devtools for MockPit.",
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/devtools/src"
  },
  "dependencies": {
    "@mockpit/browser": "workspace:*",
    "@mockpit/core": "workspace:*"
  }
}
