{
  "name": "@mockpit/msw",
  "version": "0.0.1",
  "description": "Mock Service Worker adapter for MockPit.",
  "license": "MIT",
  "author": "rerixo",
  "repository": {
    "type": "git",
    "url": "https://github.com/deltoidgg/mockpit.git",
    "directory": "packages/msw"
  },
  "homepage": "https://github.com/deltoidgg/mockpit/tree/main/packages/msw#readme",
  "bugs": "https://github.com/deltoidgg/mockpit/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/msw/src"
  },
  "dependencies": {
    "@mockpit/browser": "workspace:*",
    "@mockpit/core": "workspace:*"
  },
  "peerDependencies": {
    "msw": ">=2"
  },
  "devDependencies": {
    "msw": ">=2"
  }
}
