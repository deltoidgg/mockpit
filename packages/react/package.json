{
  "name": "@mockpit/react",
  "version": "0.0.1",
  "description": "React provider, hooks, markers, and devtools wrapper for MockPit.",
  "license": "MIT",
  "author": "rerixo",
  "repository": {
    "type": "git",
    "url": "https://github.com/deltoidgg/mockpit.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/deltoidgg/mockpit/tree/main/packages/react#readme",
  "bugs": "https://github.com/deltoidgg/mockpit/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/react/src"
  },
  "dependencies": {
    "@mockpit/browser": "workspace:*",
    "@mockpit/core": "workspace:*",
    "@mockpit/devtools": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
